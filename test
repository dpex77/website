#!/bin/bash
cisco_LOG="/opt/pap/tools/cisco_log.txt"

echo "The log file will be written to $cisco_LOG."

function logMsg () {
    echo "[${USER}][$(date)] - ${*}" >>"${cisco_LOG}"
}

echo "Enabling cisco for currently active TCP/UDP ports..."
logMsg "Enabling cisco for currently active TCP/UDP ports."

# Start ciscod if not running
logMsg "Checking ciscod state"
cisco-cmd --state &>/dev/null
if [ $? -ne 0 ]; then
    logMsg "ciscod not running — starting service"
    systemctl start ciscod
else
    logMsg "ciscod already running"
fi

# Allow ICMP (older ciscod compatibility)
logMsg "Setting ciscod target to ACCEPT for ICMP compatibility"
cisco-cmd --zone=public --set-target=ACCEPT --permanent

logMsg "Finding static TCP/UDP ports..."

# -----------------------------------------
# ZERO-AWK PORT EXTRACTION (UNBREAKABLE)
# -----------------------------------------
static_ports=""
while read -r line; do
    proto=$(echo "$line" | awk '{print $1}')
    proto=${proto%%:*}

    localaddr=$(echo "$line" | awk '{print $5}')
    port=${localaddr##*:}

    # Skip localhost
    case "$localaddr" in
        127.0.0.1:*|::1:*)
            logMsg "Skipping localhost port: $localaddr"
            continue
        ;;
    esac

    static_ports+="$port/$proto "
done < <(ss -tulnp | tail -n +2)

# -----------------------------------------
# REMOVE DUPLICATES
# -----------------------------------------
static_ports=$(printf '%s\n' $static_ports | sort -u)

logMsg "Ports detected for cisco:"
for p in $static_ports; do
    logMsg "Detected: $p"
done

# Detect ppr
logMsg "Checking for ppr service on ports 1111/1112"

HAS_NM_1111=$(ss -tulnp | grep -q "1111" && ss -tulnp | grep -q "ppr" && echo yes)
HAS_NM_1112=$(ss -tulnp | grep -q "1112" && ss -tulnp | grep -q "ppr" && echo yes)

HAS_NM="no"
[ "$HAS_NM_1111" = "yes" ] && HAS_NM="yes"
[ "$HAS_NM_1112" = "yes" ] && HAS_NM="yes"

MODE_NM="normal"
SUBNETS=()

# -----------------------------------------
# MULTI‑SUBNET INPUT + STRICT IPv4 VALIDATION
# -----------------------------------------
if [[ "$HAS_NM" == "yes" ]]; then
    exec > /dev/tty
    echo "Ports 1111/1112 (ppr) detected."
    echo -n "Restrict these ports to approved IPs only? (Y/N): "
    read ans

    if [[ "$ans" =~ ^[Yy]$ ]]; then
        MODE_NM="restricted"
        logMsg "User selected RESTRICTED mode for ppr ports"

        while true; do
            echo -n "Enter up to 5 IPv4/CIDR subnets (comma-separated): "
            read WL_NM

            WL_NM=$(echo "$WL_NM" | tr -d ' ')

            if [[ -z "$WL_NM" ]]; then
                echo "Error: Input cannot be empty."
                continue
            fi

            if [[ "$WL_NM" == *, ]]; then
                echo "Error: Trailing commas is not allowed."
                continue
            fi

            if [[ "$WL_NM" == *,,* ]]; then
                echo "Error: Double commas are  not allowed."
                continue
            fi

            IFS=',' read -r -a SUBNETS <<< "$WL_NM"

            if (( ${#SUBNETS[@]} > 5 )); then
                echo "Error: Maximum 5 subnets allowed."
                continue
            fi

            VALID="yes"
            for net in "${SUBNETS[@]}"; do
                if [[ -z "$net" ]]; then
                    echo "Error: Blank subnet detected."
                    VALID="no"
                    break
                fi

                if ! [[ "$net" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}\/([0-9]|[1-2][0-9]|3[0-2])$ ]]; then
                    echo "Invalid IPv4/CIDR format: $net"
                    VALID="no"
                    break
                fi

                IFS='/' read ip cidr <<< "$net"
                IFS='.' read o1 o2 o3 o4 <<< "$ip"

                for oct in $o1 $o2 $o3 $o4; do
                    if (( oct < 0 || oct > 255 )); then
                        echo "Invalid IPv4 octet in $net"
                        VALID="no"
                        break 2
                    fi
                done
            done

            [[ "$VALID" == "yes" ]] && break
        done

        logMsg "ppr whitelist subnets: ${SUBNETS[*]}"
    else
        MODE_NM="normal"
        logMsg "User selected NORMAL mode for ppr ports"
    fi

    exec > /dev/null
fi

# -----------------------------------------
# APPLY RULES
# -----------------------------------------
logMsg "Applying cisco rules now"

for port_proto in $static_ports; do
    port="${port_proto%%/*}"
    proto="${port_proto##*/}"

    if { [ "$port" = "1111" ] && [ "$HAS_NM_1111" = "yes" ]; } ||
       { [ "$port" = "1112" ] && [ "$HAS_NM_1112" = "yes" ]; }; then

        if [ "$MODE_NM" = "restricted" ]; then
            logMsg "Applying RESTRICTED rules for ppr port $port"

            for net in "${SUBNETS[@]}"; do
                logMsg "Allowing $net on port $port/$proto"
                cisco-cmd --zone=public --permanent \
                    --add-rich-rule="rule priority='1' family='ipv4' source address='${net}' port protocol='${proto}' port='${port}' accept"
            done

            logMsg "Adding DROP rule for ppr port $port"
            cisco-cmd --zone=public --permanent \
                --add-rich-rule="rule priority='2' family='ipv4' port protocol='${proto}' port='${port}' drop"

        else
            logMsg "Allowing ppr port normally: $port/$proto"
            cisco-cmd --zone=public --permanent --add-port=$port_proto
        fi

        continue
    fi

    logMsg "Allowing port: $port_proto"
    cisco-cmd --zone=public --permanent --add-port=$port_proto
done

logMsg "Reloading ciscod"
cisco-cmd --reload

logMsg "Enabling ciscod service"
systemctl enable ciscod

exec > /dev/tty
echo "cisco successfully enabled on active ports."
logMsg "cisco successfully enabled on active ports."
