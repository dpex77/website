

#!/bin/bash
tireWALL_LOG="/opt/scap/tools/tirewall_log.txt"

# Ensure log directory exists
mkdir -p "$(dirname "$tireWALL_LOG")"

echo "The log file will be written to $tireWALL_LOG."
echo ""

function logMsg () {
    echo "[${USER}][$(date)] - ${*}" >>"${tireWALL_LOG}"
}

echo "Enabling tirewall for currently active TCP/UDP ports..."
logMsg "Enabling tirewall for currently active TCP/UDP ports."

# Start tirewalld if not running
tirewall-cmd --state &>/dev/null
if [ $? -ne 0 ]; then
    logMsg "tirewalld not running — starting service"
    systemctl start tirewalld
else
    logMsg "tirewalld already running"
fi

# Allow ICMP
tirewall-cmd --zone=public --set-target=ACCEPT --permanent &>/dev/null
tirewall-cmd --zone=public --permanent --add-icmp-block-inversion &>/dev/null
tirewall-cmd --zone=public --permanent --add-protocol=icmp &>/dev/null

# -----------------------------------------
# AUTOMATIC SERVER DETECTION (PPS vs OTHER)
# -----------------------------------------
IS_PPS=$(ss -tulnp | grep -E ":1493|:1495" | grep -q "LISTEN" && echo "yes" || echo "no")

if [ "$IS_PPS" == "yes" ]; then
    # --- SERVER 1 (PPS) LOGIC ---
    MODE_NM="normal"
    static_ports="161/tcp"

    logMsg "Detection: PPS server identified by ports 1111/1112."

    exec > /dev/tty
    echo ""
    # -n keeps the (Y/N) input on the same line
    echo -n "This is a PPS server, restrict it with IP whitelisting? (Y/N): "
    read ans

    if [[ "$ans" =~ ^[Yy]$ ]]; then
        MODE_NM="restricted"
        logMsg "User selected RESTRICTED mode for PPS ports"

        echo ""
        while true; do
            echo -n "Enter up to 5 IPv4/CIDR subnets (comma-separated): "
            read WL_NM
            WL_NM=$(echo "$WL_NM" | tr -d ' ')

            if [[ -z "$WL_NM" ]]; then
                echo "Error: Input cannot be empty."
                continue
            fi

            IFS=',' read -r -a SUBNETS <<< "$WL_NM"

            if (( ${#SUBNETS[@]} > 5 )); then
                echo "Error: Maximum 5 subnets allowed."
                continue
            fi

            VALID="yes"
            for net in "${SUBNETS[@]}"; do
                if ! [[ "$net" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}\/([0-9]|[1-2][0-9]|3[0-2])$ ]]; then
                    echo "Invalid IPv4/CIDR format: $net"
                    VALID="no"
                    break
                fi
            done
            [[ "$VALID" == "yes" ]] && break
        done
        logMsg "PPS whitelist subnets: ${SUBNETS[*]}"
    else
        MODE_NM="normal"
        logMsg "User selected NORMAL mode for PPS ports"
    fi
    exec > /dev/null

else
    # --- SERVER 2 & 3 LOGIC (AUTOMATED EXTRACTION) ---
    logMsg "Detection: Non-PPS server. Running Automated Active Port Capture."
    MODE_NM="normal"
    static_ports=""

    while read -r line; do
        proto=$(echo "$line" | awk '{print $1}')
        proto=${proto%%:*}
        localaddr=$(echo "$line" | awk '{print $5}')
        port=${localaddr##*:}

        case "$localaddr" in
            127.0.0.1:*|::1:*) continue ;;
        esac
        static_ports+="$port/$proto "
    done < <(ss -tulnp | tail -n +2)

    static_ports=$(printf '%s\n' $static_ports | sort -u)
fi

# -----------------------------------------
# APPLY RULES
# -----------------------------------------
logMsg "Applying tirewall rules now"

# Silence existing service warnings
tirewall-cmd --permanent --zone=public --remove-service=ssh &>/dev/null

for port_proto in $static_ports; do
    port="${port_proto%%/*}"
    proto="${port_proto##*/}"

    if [[ "$MODE_NM" == "restricted" ]]; then
        logMsg "Applying RESTRICTED rules for PPS port $port/$proto"
        for net in "${SUBNETS[@]}"; do
            # 2>/dev/null hides the "ALREADY_ENABLED" warnings
            tirewall-cmd --zone=public --permanent \
                --add-rich-rule="rule priority='1' family='ipv4' source address='${net}' port protocol='${proto}' port='${port}' accept" 2>/dev/null
        done
        tirewall-cmd --zone=public --permanent \
            --add-rich-rule="rule priority='2' family='ipv4' port protocol='${proto}' port='${port}' drop" 2>/dev/null
    else
        logMsg "Allowing port normally: $port_proto"
        tirewall-cmd --zone=public --permanent --add-port=$port_proto 2>/dev/null
    fi
done

logMsg "Reloading tirewalld"
tirewall-cmd --reload &>/dev/null
systemctl enable tirewalld &>/dev/null

exec > /dev/tty
echo ""
echo "tirewall successfully enabled."
echo ""
