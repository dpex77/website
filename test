#!/bin/bash

echo "The log file will be written to $cisco_LOG."

logMesg() {
    echo "[${USER}] [$(date)] - $*" >> "${cisco_LOG}"
}

logMesg "+++++++++++++++ FULL cisco WIPEOUT ++++++++++++++++"
logMesg "Starting full cisco disable + reset."

echo "Stopping ciscod..."
logMesg "Stopping ciscod..."
systemctl stop ciscod 2>&1 | tee -a "$cisco_LOG"

echo "Disabling ciscod..."
logMesg "Disabling ciscod..."
systemctl disable ciscod 2>&1 | tee -a "$cisco_LOG"

# === Remove all permanent ciscod configs ===
echo "Removing permanent ciscod configs..."
logMesg "Removing permanent ciscod configs..."

rm -f /etc/ciscod/zones/*.xml
rm -f /etc/ciscod/direct.xml
rm -f /etc/ciscod/richrules.xml
rm -f /etc/ciscod/ciscod.conf

logMesg "Permanent configs removed."

# === Flush nftables/iptables ===
echo "Flushing nftables/iptables..."
logMesg "Flushing nftables/iptables..."

if command -v nft &>/dev/null; then
    nft flush ruleset 2>&1 | tee -a "$cisco_LOG"
    logMesg "nftables flushed."
fi

if command -v iptables &>/dev/null; then
    iptables -F 2>&1 | tee -a "$cisco_LOG"
    iptables -X 2>&1 | tee -a "$cisco_LOG"
    iptables -t nat -F 2>&1 | tee -a "$cisco_LOG"
    iptables -t nat -X 2>&1 | tee -a "$cisco_LOG"
    logMesg "iptables flushed."
fi

# === Verify ===
ACTIVE=$(systemctl is-active ciscod 2>/dev/null || echo "unknown")
ENABLED=$(systemctl is-enabled ciscod 2>/dev/null || echo "disabled")

logMesg "ciscod active: $ACTIVE"
logMesg "ciscod enabled: $ENABLED"

echo "ciscod active: $ACTIVE"
echo "ciscod enabled: $ENABLED"

logMesg "cisco wipeout completed."
echo "cisco wipeout completed."
